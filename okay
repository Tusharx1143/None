import json

__log = logging.getLogger('rest_routes')

def check_admin_url():
    response = do_post('/healthcheck', payload={}, auth=None, expected_status=200)
    return response is not None

def connect_to_admin():
    return check_admin_url()

def run_health_checks():
    while True:
        if not check_admin_url():
            __log.warning("Admin URL is down. Attempting to reconnect...")
            connect_to_admin()
        else:
            __log.info("Admin URL is healthy.")
        time.sleep(30)

