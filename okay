                                                  pool_size=5,
                                                  pool_reset_session=True,
                                                  host=config.get_arg("assetstore.db.host"),
                                                  port=config.get_arg("assetstore.db.port"),
                                                  database=config.get_arg("automation.db.database"),
                                                  user=config.get_arg("spring.datasource.username"),
