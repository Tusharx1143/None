login_manager.login_view = 'login'

class User(UserMixin):
    def __init__(self, username):
        self.id = username

@login_manager.user_loader
def load_user(user_id):
    return User(user_id)

@rest_endpoint.route('/logout', methods=['GET', 'POST'])
def logout():
    logout_user()
    return redirect(url_for('login'))

@rest_endpoint.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        response = ldap_manager.authenticate(username, password)
        if response.status == AuthenticationResponseStatus.success:
            user = User(username)
            login_user(user)
            return redirect(url_for('index'))
        else:
            flash('Invalid username or password')
            return redirect(url_for('login'))
    return render_template('login.html', title="PlainID Management Automation | " + config.get_environment_name())

@rest_endpoint.route('/authenticate', methods=['GET'])
def authenticate():
    auth = request.authorization
    if not auth or not auth.username or not auth.password:
        return "Unauthorized", HTTPStatus.FORBIDDEN

    response = ldap_manager.authenticate(auth.username, auth.password)
    if response.status == AuthenticationResponseStatus.success:
        user = User(auth.username)
        login_user(user)
        return "Success", HTTPStatus.OK
    else:
        return "Unauthorized", HTTPStatus.FORBIDDEN

@rest_endpoint.route('/keepalive', methods=['GET'])
