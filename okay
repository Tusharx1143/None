Unit Tests for rest_utils.py:

import unittest
from unittest.mock import patch, call
import requests
from rest_utils import do_post, do_put

class TestRestUtils(unittest.TestCase):

    @patch('rest_utils.requests.post')
    def test_do_post_success(self, mock_post):
        mock_post.return_value.status_code = 200
        mock_post.return_value.text = 'Success'

        response = do_post('/some_endpoint', payload={'key': 'value'}, auth=None, expected_status=200)
        self.assertEqual(response, 'Success')
        mock_post.assert_called_once()

    @patch('rest_utils.requests.post')
    def test_do_post_retry(self, mock_post):
        mock_post.side_effect = [requests.exceptions.RequestException, requests.exceptions.RequestException,
                                 unittest.mock.Mock(status_code=200, text='Success')]

        response = do_post('/some_endpoint', payload={'key': 'value'}, auth=None, expected_status=200)
        self.assertEqual(response, 'Success')
        self.assertEqual(mock_post.call_count, 3)

    @patch('rest_utils.requests.put')
    def test_do_put_success(self, mock_put):
        mock_put.return_value.status_code = 200

        response = do_put('/some_endpoint', payload={'key': 'value'}, auth=None, expected_status=200)
        self.assertTrue(response)
        mock_put.assert_called_once()

    @patch('rest_utils.requests.put')
    def test_do_put_retry(self, mock_put):
        mock_put.side_effect = [requests.exceptions.RequestException, requests.exceptions.RequestException,
                                unittest.mock.Mock(status_code=200)]

        response = do_put('/some_endpoint', payload={'key': 'value'}, auth=None, expected_status=200)
        self.assertTrue(response)
        self.assertEqual(mock_put.call_count, 3)

if __name__ == '__main__':
    unittest.main()
