def create_application_set_in_asset_store(application_name, cmdb_application_id):
    """
    Create a new application set in the Asset Store using the CMDB application ID.
    
    Args:
    - application_name (str): The name of the application.
    - cmdb_application_id (str): The ID of the CMDB application.
    
    Returns:
    - dict: The response from the Asset Store API (application set details).
    """
    application_set_data = {
        "application_cmdb_sys_id": cmdb_application_id,
        "application_set_name": f"{application_name} Application Set",
        "application_set_description": f"Asset Store migration for {application_name}"
    }
    
    try:
        url = f"{api_url}/applicationsets"
        response = requests.post(url, headers=headers, data=json.dumps(application_set_data))
        if response.status_code == HTTPStatus.OK:
            _log.info(f"Successfully created application set for {application_name}")
            return response.json()
        else:
            _log.error(f"Failed to create application set for {application_name}. Status: {response.status_code}")
            return {}
    except Exception as error:
        _log.error(f"Error creating application set for {application_name}: {str(error)}")
        return {}

Explanation: This function uses the POST /asset/api/v1/applicationsets API to create an application set in the Asset Store using the cmdb_applicationId.


