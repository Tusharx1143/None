def migrate_cmdb_application_to_asset_store(application_name):
    """
    Migrate or update a CMDB application and its resources to the Asset Store.
    
    Args:
    - application_name (str): The name of the CMDB application to migrate.
    
    Returns:
    - None
    """
    cmdb_app = get_cmdb_application_by_id(application_name)
    
    if cmdb_app:
        cmdb_application_id = cmdb_app["cmdb_application_id"]
        
        # Step 2: Create or Update Application Set in Asset Store
        application_set_response = create_application_set_in_asset_store(application_name, cmdb_application_id)
        
        if "applicationSet" in application_set_response:
            _log.info(f"Application set for {application_name} created or updated successfully")
        else:
            _log.error(f"Failed to create or update Application Set for {application_name}")
    else:
        _log.error(f"CMDB application {application_name} not found.")


