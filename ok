def map_rodan_resources_to_asset_store(application_set_id, rodan_resources):
    """
    Map and create resources from RODAN in the Asset Store.
    
    Args:
    - application_set_id (str): The application set ID in which the resources should be created.
    - rodan_resources (list): A list of resources extracted from RODAN.
    
    Returns:
    - dict: A dictionary with resource names as keys and the corresponding Asset Store resource IDs as values.
    """
    resources_dict = {}
    for resource_name in rodan_resources:
        try:
            resource_response = create_resource(application_set_id, resource_type_id=None, resource_name=resource_name)
            resources_dict[resource_name] = resource_response.get('resource_map_key')
            _log.info(f"Resource {resource_name} created successfully in Asset Store")
        except Exception as error:
            _log.error(f"Failed to create resource {resource_name}: {str(error)}")
    return resources_dict

