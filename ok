Simplified Jenkinsfile:

pipeline {
    agent { 
        label 'Linux && region=eu && jdk-17-zulu && python-3.11' 
    }

    environment {
        PYTHON_ENV = '/usr/bin/python3.11'
        VENV_DIR = 'venv'
        REQUIREMENTS_PATH = 'resources/requirements.txt'
    }

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()  // Clean workspace before starting
                checkout([$class: 'GitSCM', branches: [[name: '*/main']], userRemoteConfigs: [[url: '<GIT_REPO_URL>']]])
            }
        }

        stage('Check Environment') {
            steps {
                script {
                    sh '''
                    echo "Current PATH: $PATH"
                    echo "Listing Python versions available in /usr/bin/"
                    ls /usr/bin/python*
                    echo "Trying to find python3.11 using 'which' command:"
                    which python3.11 || echo "python3.11 not found!"
                    '''
                }
            }
        }

        stage('Setup Python Environment') {
            steps {
                script {
                    sh '''
                    # Check if Python 3.11 is available
                    if command -v ${PYTHON_ENV} &> /dev/null
                    then
                        echo "Python 3.11 found at ${PYTHON_ENV}"
                    else
                        echo "Python 3.11 not found at ${PYTHON_ENV}! Please check the PYTHON_ENV variable."
                        exit 1
                    fi
                    
                    # Set up the virtual environment
                    ${PYTHON_ENV} -m venv ${VENV_DIR}
                    source ${VENV_DIR}/bin/activate
                    pip install --upgrade pip
                    pip install requests-mock

                    # Install dependencies from requirements.txt
                    if [ -f ${REQUIREMENTS_PATH} ]; then
                        pip install -r ${REQUIREMENTS_PATH}
                    else
                        echo "Requirements file not found at ${REQUIREMENTS_PATH}"
                        exit 1
                    fi
                    '''
                }
            }
        }

        stage('Run Python Unittests') {
            steps {
                script {
                    sh '''
                    # Create the reports directory
                    mkdir -p reports
                    
                    # Run Python unittests
                    source ${VENV_DIR}/bin/activate
                    python -m unittest discover -s unittests -p '*.py'
                    
                    # Check if test results exist
                    echo "Checking if test results were generated..."
                    if [ -f reports/results.xml ]; then
                        echo "Test results found."
                    else
                        echo "No test results found."
                    fi
                    '''
                }
            }
        }

        stage('Build') {
            when { expression { !shouldPerformReleaseBuild() } }
            steps {
                script {
                    runMaven('clean deploy -U -B')
                }
            }
        }

        stage('Release Packaging') {
            when { expression { shouldPerformReleaseBuild() } }
            steps {
                script {
                    sh '''
                    export IQ_SCAN_STAGE='release'
                    sshagent(['devops-key']) {
                        runMaven('-U -B -Darguments="-Dmaven.javadoc.skip=true" release:clean release:prepare release:perform')
                    }
                    '''
                }
            }
        }

        stage('Nexus IQ Policy Evaluation & Upload') {
            steps {
                script {
                    sh '''
                    echo 'Branch is on master, performing snapshot deploy steps'
                    nexusPolicyEvaluation(
                        advancedProperties: '',
                        failBuildOnNetworkError: false,
                        iqApplication: selectedApplication("${NEXUS_IQ_APPLICATION_ID}"),
                        iqStage: "${IQ_SCAN_STAGE}",
                        jobCredentialsId: 'admin'
                    )
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
                    junit '**/report.xml'
                }
            }
        }
    }

    post {
        always {
            cleanWs()  // Clean workspace after build
        }
    }
}

def shouldPerformReleaseBuild() {
    return params.PERFORM_RELEASE
}

Key Adjustments:

1. Check Environment: The script checks if Python 3.11 is available.


2. Setup Python Environment: It sets up a virtual environment and installs dependencies from requirements.txt.


3. Run Python Unittests: It uses unittest to discover and run tests, and logs whether test results were found.


4. Maven Build: The Maven build is only performed when not running a release.


5. Release Packaging: If PERFORM_RELEASE is true, it packages the release.


6. Nexus IQ Evaluation: If on the master branch, it performs Nexus IQ evaluation.


7. Post Steps: Archive artifacts and clean up the workspace.



