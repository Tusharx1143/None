from config import config
import requests
import logging

_log = logging.getLogger("config")

asset_store_base_url = config.get_arg("assetstore.url")
asset_store_api_url = asset_store_base_url + "/applicationsets"
asset_store_user = config.get_arg("assetstore.user")
asset_store_password = config.get_arg("assetstore.password")

def create_application_set_in_asset_store(application_name, cmdb_application_id):
    """
    Create an Application Set in the Asset Store with more detailed information.
    
    Args:
    - application_name (str): Name of the application.
    - cmdb_application_id (str): CMDB Application ID.
    
    Returns:
    - dict: Response from the Asset Store.
    """
    # Prepare the payload with the required fields and values
    application_set_data = {
        "applicationSet": f"{application_name} Application Set",
        "applicationName": application_name,
        "applicationSetCmdDbApplicationInstances": [
            {
                "cmdbApplicationInstanceId": "Instance_Id_Here"  # Replace with actual instance ID
            }
        ],
        "applicationSetResourceTypes": [
            {
                "resourceType": "Resource_Type_Here",  # Replace with actual resource type
                "attributes": [
                    {
                        "attribute": "Attribute_1",
                        "dataType": "String"
                    },
                    {
                        "attribute": "Attribute_2",
                        "dataType": "Numeric"
                    }
                ],
                "actions": [
                    {
                        "action": "Action_1"  # Replace with actual action
                    }
                ]
            }
        ],
        "cmdbApplicationId": cmdb_application_id,
        "cmdbApplicationDescription": application_name
    }

    # Send the POST request to create the application set
    try:
        _log.info("Attempting to create application set at %s", asset_store_api_url)
        _log.info("Payload: %s", application_set_data)
        
        response = requests.post(
            url=asset_store_api_url,
            json=application_set_data,
            auth=(asset_store_user, asset_store_password),
            headers={"Content-type": "application/json"}
        )
        
        if response.status_code in [200, 201]:
            _log.info("Successfully created application set for %s", application_name)
            return response.json()
        else:
            _log.error("Failed to create application set for %s. Status: %s, Response: %s",
                       application_name, response.status_code, response.text)
            return {}
    except Exception as e:
        _log.error("Error while creating application set: %s", str(e))
        return {}


















