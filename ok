def test_deploy_to_plainid(self):
    logging.debug("Testing deploy_to_plainid function")
    
    from utils.scope import deploy_to_plainid

    deploy_to_plainid('test_client_id')

    actual_call = self.mock_request.call_args
    print(f"Actual call parameters: {actual_call}")

    args, kwargs = actual_call
    print(f"Positional arguments: {args}")
    print(f"Keyword arguments: {kwargs}")

    self.assertEqual(kwargs['auth'], ('mock_user_8640', 'mock_password_9191'))
    self.assertEqual(kwargs['method'], 'GET')
    self.assertEqual(kwargs['url'], 'https://mock-plainid.url.test/rest/deployer/deploy/test_client_id')
    self.assertEqual(kwargs['headers'], {'Content-Type': 'application/json'})
    
    self.mock_request.assert_called_with(
        allow_redirects=kwargs.get('allow_redirects', None),
        auth=('mock_user_8640', 'mock_password_9191'),
        headers={'Content-Type': 'application/json'},
        method='GET',
        params=kwargs.get('params', None),
        url='https://mock-plainid.url.test/rest/deployer/deploy/test_client_id'
    )

    logging.debug(f"Network request mocked successfully, call details: {actual_call}")
