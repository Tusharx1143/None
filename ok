def create_snow_groups(application):
    CMDB_DEVELOPMENT_GROUP = "_dev_support_group"
    CMDB_SUPPORT_GROUP = "_support_group"
    CMDB_ENVIRONMENT = "_my_environment"
    CMDB_ACTIVE = "u_active"
    environment = "DEV"
    
    if config.get_propstore_env() in [Environments.Demo, Environments.Production]:
        environment = "PROD"

    dev_snow_groups = set()
    support_snow_groups = set()

    cmdb_url = config.get_arg("cmdb.url") + "/applications/" + application + "/appinstances?type=JSON"
    r = requests.get(url=cmdb_url, auth=(cmdb_user, cmdb_password))
    
    try:
        app_instances = r.json()["result"]
        _log.info("CMDB Response for application %s: %s", application, json.dumps(app_instances, indent=4))
        
        for app_instance in app_instances:
            _log.info("Checking instance: Active: %s, Environment: %s", app_instance[CMDB_ACTIVE], app_instance[CMDB_ENVIRONMENT])
            
            if app_instance[CMDB_ACTIVE] == "true" or app_instance[CMDB_ENVIRONMENT] != environment:
                _log.info("Skipping instance: Active: %s, Environment: %s", app_instance[CMDB_ACTIVE], app_instance[CMDB_ENVIRONMENT])
                continue

            if app_instance[CMDB_DEVELOPMENT_GROUP] is not None:
                dev_snow_groups.add(app_instance[CMDB_DEVELOPMENT_GROUP])
                _log.info("Found Development Group: %s", app_instance[CMDB_DEVELOPMENT_GROUP])
                
            if app_instance[CMDB_SUPPORT_GROUP] is not None:
                support_snow_groups.add(app_instance[CMDB_SUPPORT_GROUP])
                _log.info("Found Support Group: %s", app_instance[CMDB_SUPPORT_GROUP])

        if len(dev_snow_groups) == 0:
            _log.error("No Snow groups for development found")
            raise MissingSnowGroupsException("No Snow groups for development found")
        if len(support_snow_groups) == 0:
            _log.error("No Snow groups for support found")
            raise MissingSnowGroupsException("No Snow groups for support found")

        # Always return both sets, even if they are empty
        return dev_snow_groups, support_snow_groups

    except MissingSnowGroupsException as ex:
        _log.error(f"Error: {str(ex)}")
        return set(), set()  # Returning empty sets to avoid unpacking error
    except Exception as error:
        if r.status_code == HTTPStatus.NOT_FOUND:
            _log.error("Incorrect App Name or App not present in CMDB: " + application)
        else:
            _log.error("Error processing request for %s: %s", application, str(error))
        return set(), set()  # Always return sets, even in case of error
