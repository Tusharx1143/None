def link_dynamic_list_to_policy(permission, resources):
    """
    Link a dynamic list to a policy.
    
    Args:
    - permission (str): The permission ID to link.
    - resources (list): List of resource IDs to link to the permission.
    """
    data = [{
        "permission": permission,
        "resources": resources
    }]

    _log.info("Linking dynamic list to policy")
    try:
        url = base_url + "/rest/xresource/link"
        r = requests.post(url=url, data=json.dumps(data), auth=(plainid_user, plainid_password), headers=headers)
        response = r.json()
        if r.status_code == HTTPStatus.OK:
            _log.info("Linked dynamic list to policy")
        else:
            _log.debug("Unexpected response code from REST call: " + str(r))
    except Exception as error:
        _log.error("Error linking dynamic list to policy: %s %s", str(error), sys.exc_info())
        raise error

def create_application_set(application_cmdb_sys_id, application_set_name, application_set_description):
    """
    Create an application set in the Asset Store.
    
    Args:
    - application_cmdb_sys_id (str): CMDB system ID for the application.
    - application_set_name (str): Name of the application set.
    - application_set_description (str): Description of the application set.
    
    Returns:
    - dict: The response from the Asset Store API.
    """
    try:
        payload = {
            "application_cmdb_sys_id": application_cmdb_sys_id,
            "application_set_name": application_set_name,
            "application_set_description": application_set_description
        }

        r = requests.post(url=asset_store_api_url, data=json.dumps(payload), headers=headers,
                          auth=(asset_store_user, asset_store_password))
        if r.status_code == HTTPStatus.OK:
            response = r.json()
            _log.info("Application set created successfully")
            return {"response": response}
        else:
            _log.debug("Unexpected response code from REST call: " + str(r))
            raise Exception(r)
    except Exception as error:
        _log.error("Error creating application set: %s %s", str(error), sys.exc_info())
        raise Exception(str(error))

def create_policies_based_on_resource(application, resource, action_filter):
    """
    Create policies based on a given resource and action filter.
    
    Args:
    - application (str): The name of the application.
    - resource (str): The resource for which to create policies.
    - action_filter (str): Filter for specific actions.
    
    Returns:
    - bool: True if policies are created successfully.
    """
    # Pre-flight checks
    cmdb_app = cmdb_application.get_cmdb_application(application)
    if not cmdb_app:
        raise Exception(f"Application {application} not found in CMDB!")
    application_sys_id = cmdb_app['sys_id']
    ns = namespace.get_namespace_or_throw(application)
    if ns is not None:
        namespace_id = ns['id']

    # Fetch entitlements from RODAN using resource string
    try:
        entitlements_list = entitlements.get_entitlements(resource, action_filter)['entitlements']['entitlement']
    except Exception as error:
        raise Exception(f"Error while fetching entitlements for resource: {resource}")

    # Set of actions and groups
    rodan_actions = set()
    rodan_groups = set()

    for entitlement in entitlements_list:
        if "group" in entitlement and entitlement["deny"] == "false":
            rodan_actions.add(entitlement["action"])
            rodan_groups.add(entitlement["group"])

    if len(rodan_actions) == 0:
        raise Exception("No actions found in entitlements")
    if len(rodan_groups) == 0:
        raise Exception("No groups found in entitlements")

    # Get the master list of actions from the asset store
    asset_store_action_list = action.get_asset_store_actions()
    if len(asset_store_action_list) == 0:
        raise Exception("No actions found in asset store")

    # Verify all actions exist in asset store and PlainID
    for action_name in sorted(rodan_actions):
        if action_name not in asset_store_action_list:
            raise Exception(f"Action {action_name} is missing from Asset store")
        plainid_action = get_action_by_name(action_name)
        if plainid_action is None:
            raise Exception(f"Action {action_name} is missing from PlainID")

    # Create dynamic groups into global namespace (existing functionality)
    groups_dict = {}
    # for group_name in rodan_groups:
    #     dynamic_group_response = groups.create(group_type="swarm", group_name=group_name, group_description=group_name)
    #     groups_dict.update({group_name: dynamic_group_response['id']})

    # Create policies and link resources
    actions_dict = {}
    try:
        for action_name in sorted(rodan_actions):
            policy_name = f"{application}-{action_name}-Access"
            description = policy_name
            policy = create_policy(namespace_id, policy_name, description)
            actions_dict.update({action_name: policy['id']})

            # Create resource type and resource in Asset Store
            resource_type_response = create_resource_type("RODAN", application_sys_id)
            resource_type_id = resource_type_response['resource_type_application_set_key']
            resource_response = create_resource(application_sys_id, resource_type_id, resource)
            resource_id = resource_response['resource_map_key']

            # Link resource to policy
            link_resources_to_policy(policy['id'], [resource_id])

            _log.info(f"Policy {policy_name} created and resource {resource} linked successfully.")
    except Exception as error:
        raise Exception(f"Error while creating policy and linking resources: {str(error)}")

    # Link dynamic groups to policy
    for entitlement in entitlements_list:
        if "group" in entitlement and entitlement["deny"] == "false":
            current_group = groups_dict[entitlement["group"]]
            current_policy = actions_dict[entitlement["action"]]

            data = [current_group]
            dynamic_group_url = f"{api_url}/{current_policy}/permissionRule/dynamic"
            headers.update({"namespace": namespace_id})

            _log.info(f"Link the dynamic group {data} in the policy {current_policy}")
            try:
                r = requests.post(url=dynamic_group_url, data=json.dumps(data), auth=(plainid_user, plainid_password), headers=headers)
                if r.status_code == HTTPStatus.OK:
                    _log.info("Linked the dynamic group to the policy successfully")
                else:
                    _log.debug(f"Unexpected response code from REST call: {r.status_code}")
            except Exception as error:
                _log.error("Error linking dynamic group to policy: %s %s", str(error), sys.exc_info())
                raise error

    return True

def get_resource_id_by_name(resource_name):
    """
    Retrieve resource ID by resource name.
    
    Args:
    - resource_name (str): The name of the resource.
    
    Returns:
    - str: The resource ID.
    """
    resource_obj = db_objects.get_object_by_name(resource_name, DYNAMIC_LIST_OBJ, base_url,
                                                 auth=(plainid_user, plainid_password))
    return resource_obj['id']

def get_action_by_name(action_name):
    """
    Retrieve action ID by action name.
    
    Args:
    - action_name (str): The name of the action.
    
    Returns:
    - dict: The action object.
    """
    action = db_objects.get_object_by_name(action_name, ACTION_OBJ, base_url,
                                           auth=(plainid_user, plainid_password))
    return action

def link_resources_to_policy(policy_id, resource_ids):
    """
    Link resources to a given policy.
    
    Args:
    - policy_id (str): The ID of the policy.
    - resource_ids (list): List of resource IDs to link to the policy.
    
    Returns:
    - None
    """
    data = {
        "resources": resource_ids
    }

    try:
        url = f"{api_url}/{policy_id}/resources"
        response = requests.post(url=url, data=json.dumps(data), headers=headers, auth=(plainid_user, plainid_password))
        if response.status_code == HTTPStatus.OK:
            _log.info("Resources linked to policy successfully")
        else:
            _log.debug(f"Unexpected response code from REST call: {response.status_code}")
            raise Exception(response.text)
    except Exception as error:
        _log.error("Error linking resources to policy: %s %s", str(error), sys.exc_info())
        raise error





