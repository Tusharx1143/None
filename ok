
import requests
import logging

# Configure logging
logging.basicConfig(level=logging.INFO)
_log = logging.getLogger(__name__)

# Update with your actual asset store base URL and credentials
asset_store_base_url = "http://your_asset_store_base_url"
asset_store_api_url = asset_store_base_url + "/api/v1/applicationsets"  # Endpoint to delete application sets
asset_store_user = "your_asset_store_user"
asset_store_password = "your_asset_store_password"

def delete_application_set(application_set_id):
    """
    Delete an existing application set from the Asset Store.
    
    Args:
    - application_set_id (str): The ID of the application set to delete.
    
    Returns:
    - None
    """
    # Construct the delete URL
    delete_url = f"{asset_store_api_url}/{application_set_id}"
    
    try:
        _log.info(f"Attempting to delete application set with ID: {application_set_id}")
        
        # Make the DELETE request to the asset store API
        response = requests.delete(url=delete_url, auth=(asset_store_user, asset_store_password))
        
        # Check the response status
        if response.status_code == 200:
            _log.info(f"Successfully deleted application set with ID: {application_set_id}")
        else:
            _log.error(f"Failed to delete application set with ID: {application_set_id}. Status: {response.status_code}")
            _log.error(f"Response: {response.json()}")
    except Exception as e:
        _log.error(f"Error occurred while deleting application set: {str(e)}")

# Example usage:
if __name__ == "__main__":
    application_set_id = "your_application_set_id_here"  # Replace with your actual application set ID
    delete_application_set(application_set_id)
