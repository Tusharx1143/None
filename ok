def create_application_set_in_asset_store(application_name, cmdb_application_id):
    """
    Create or update an Application Set in the Asset Store.
    
    Args:
    - application_name (str): The name of the application set.
    - cmdb_application_id (str): The ID of the CMDB application.
    
    Returns:
    - dict: Response from the Asset Store.
    """
    # Define the application set data with complete information
    application_set_data = {
        "applicationSet": f"{application_name} Application Set",
        "applicationName": application_name,
        "applicationSetCmdbApplicationInstances": [
            {
                "cmdbApplicationInstanceId": "4c14231d1baf00956c95354604bcbee"  # Example instance ID
            }
        ],
        "applicationSetResourceTypes": [
            {
                "resourceType": "Resource Type 1",
                "attributes": [
                    {
                        "attribute": "Attribute Type 1",
                        "dataType": "String"
                    },
                    {
                        "attribute": "Attribute Type 2",
                        "dataType": "Numeric"
                    }
                ],
                "actions": [
                    {
                        "action": "Readonly"
                    }
                ]
            }
        ],
        "cmdbApplicationId": cmdb_application_id,
        "cmdbApplicationDescription": application_name
    }

    try:
        _log.info(f"Attempting to create or update application set at {asset_store_test_url}")
        _log.info(f"Payload: {application_set_data}")
        _log.info(f"Headers: {headers}")
        
        response = requests.put(
            asset_store_test_url,
            headers=headers,
            data=json.dumps(application_set_data),
            auth=(asset_store_user, asset_store_password)
        )
        
        if response.status_code == HTTPStatus.OK:
            _log.info(f"Successfully created or updated application set for {application_name}")
            return response.json()
        else:
            response_text = response.text
            _log.error(f"Failed to create or update application set for {application_name}. Status: {response.status_code}, Response: {response_text}")
            return {}
    except Exception as error:
        _log.error(f"Error creating or updating application set for {application_name}: {str(error)}")
        return {}





