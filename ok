1. entitlements.py
New Function: fetch_and_filter_entitlements

Purpose: This function will fetch entitlements from RODAN using the provided resource query and action filter. It will filter out user-based entitlements and deny entitlements.
Why Needed: To automate the extraction and filtering of entitlements that are relevant for creating policies in PlainID.

def fetch_and_filter_entitlements(resource_query_string, action_filter=None):
    """
    Fetch entitlements from RODAN and filter out user-based and deny entitlements.
    
    Args:
    - resource_query_string (str): The resource query string to use for fetching entitlements.
    - action_filter (str): Optional filter for specific actions.
    
    Returns:
    - list: Filtered entitlements.
    """
    try:
        entitlements_list = get_entitlements(resource_query_string, action_filter)['entitlements']['entitlement']
        filtered_entitlements = [
            ent for ent in entitlements_list if "group" in ent and ent.get("deny", "false") == "false"
        ]
        return filtered_entitlements
    except Exception as error:
        _log.error("Error while fetching entitlements: %s", str(error))
        return []

# Example usage
filtered_entitlements = fetch_and_filter_entitlements("resource_query_string_here")

