2. groups.py
New Function: create_dynamic_groups_for_entitlements

Purpose: This function will create dynamic groups in PlainID based on the groups listed in the RODAN entitlements.
Why Needed: To automate the group creation process, ensuring that the appropriate groups exist in PlainID for policy linking.

def create_dynamic_groups_for_entitlements(entitlements):
    """
    Create dynamic groups in PlainID based on RODAN entitlements.
    
    Args:
    - entitlements (list): List of entitlements containing group names.
    
    Returns:
    - dict: Mapping of group names to group IDs.
    """
    groups_dict = {}
    for entitlement in entitlements:
        group_name = entitlement["group"]
        response = create(group_type="swarm", group_name=group_name, group_description=group_name)
        if response and "id" in response:
            groups_dict[group_name] = response["id"]
        else:
            _log.error("Failed to create group: %s", group_name)
    return groups_dict

# Example usage
group_ids = create_dynamic_groups_for_entitlements(filtered_entitlements)


