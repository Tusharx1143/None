library 'devops@develop'
pipeline {
    agent { label 'linux && region-eu && jdk-8-zulu' }
    
    parameters {
        booleanParam(name: 'PERFORM_RELEASE', defaultValue: false, description: 'Tick this box if you want to run a release')
    }
    
    environment {
        JAVA_TOOL_NAME = 'Zulu JDK 8'
        MAVEN_TOOL_NAME = 'Maven 3'
        MAVEN_PROJECT_SETTINGS_ID = 'plainid-maven-settings'
        MAVEN_GLOBAL_SETTINGS_ID = 'JenkinsSystemGlobalMavenSettings'
        NEXUS_IQ_APPLICATION_ID = 'plainid-management-automation'
        SSH_PUSH_KEY = 'devops-key'
        IQ_SCAN_STAGE = 'build'
        PYTHON_ENV = '/usr/bin/python3.11' // Path to Python 3.11
        VENV_DIR = 'venv' // Directory for Python virtual environment
    }
    
    options {
        skipDefaultCheckout(true)
        timestamps()
    }
    
    stages {
        stage('Checkout') {
            steps {
                cleanWs() // Clean workspace
                checkout([$class: 'GitSCM', 
                          branches: scm.branches, 
                          extensions: [
                              [$class: 'CloneOption', noTags: false],
                              [$class: 'LocalBranch', localBranch: '**'] 
                          ],
                          userRemoteConfigs: scm.userRemoteConfigs 
                ])
            }
        }

        stage('Setup Python Environment') {
            steps {
                script {
                    // Setup Python virtual environment
                    sh '''
                        ${PYTHON_ENV} --version
                        ${PYTHON_ENV} -m venv ${VENV_DIR}
                        source ${VENV_DIR}/bin/activate
                        pip install --upgrade pip
                        if [ -f requirements.txt ]; then
                            pip install -r requirements.txt
                        else
                            echo "No requirements.txt found, skipping Python dependency installation."
                        fi
                    '''
                }
            }
        }

        stage('Run Python Unittests') {
            steps {
                script {
                    // Run Python unittests
                    sh '''
                        source ${VENV_DIR}/bin/activate
                        pytest unittests/ --junitxml=report.xml
                    '''
                }
            }
        }

        stage('Build') {
            when { expression { !shouldPerformReleaseBuild() } }
            steps {
                script {
                    runMaven('clean deploy -U -B')
                }
            }
        }

        stage('Release Packaging') {
            when { expression { shouldPerformReleaseBuild() } }
            steps {
                script {
                    IQ_SCAN_STAGE = 'release'
                    sshagent(["${env.SSH_PUSH_KEY}"]) {
                        runMaven("-U -B -Darguments='-Dmaven.javadoc.skip=true' release:clean release:prepare release:perform")
                    }
                }
            }
        }

        stage('Nexus IQ Policy Evaluation & Upload') {
            steps {
                script {
                    echo 'Branch is on master, performing snapshot deploy steps'
                    nexusPolicyEvaluation(
                        advancedProperties: '',
                        failBuildOnNetworkError: false,
                        iqApplication: selectedApplication("${NEXUS_IQ_APPLICATION_ID}"),
                        iqStage: "${IQ_SCAN_STAGE}",
                        jobCredentialsId: 'admin'
                    )
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
            junit '**/report.xml' // Archive Python test results
        }
    }
}

private boolean shouldPerformReleaseBuild() {
    return params.PERFORM_RELEASE
}

private void runMaven(String mvnArgs) {
    wrap([$class: 'BuildUser']) {
        builder.gitSetUserConfig("${env.BUILD_USER}", "${env.BUILD_USER_EMAIL}")
        withMaven(
            jdk: "${env.JAVA_TOOL_NAME}",
            maven: "${env.MAVEN_TOOL_NAME}",
            globalMavenSettingsConfig: "${env.MAVEN_GLOBAL_SETTINGS_ID}",
            mavenSettingsConfig: "${env.MAVEN_PROJECT_SETTINGS_ID}") {
                if (isUnix()) {
                    sh "mvn ${mvnArgs}"
                } else {
                    bat "mvn ${mvnArgs}"
                }
        }
    }
}




