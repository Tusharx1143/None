import unittest
from unittest.mock import patch, Mock
from policies import link_resources_to_policy

class TestPolicies(unittest.TestCase):

    @patch('policies.requests.post')
    def test_link_resources_to_policy_success(self, mock_post):
        mock_response = Mock()
        mock_response.status_code = 200
        mock_post.return_value = mock_response

        result = link_resources_to_policy("test_policy_id", ["resource1", "resource2"])
        self.assertIsNone(result)
        mock_post.assert_called_once()

    @patch('policies.requests.post')
    def test_link_resources_to_policy_failure(self, mock_post):
        mock_response = Mock()
        mock_response.status_code = 400
        mock_response.text = 'Error linking resources'
        mock_post.return_value = mock_response

        with self.assertRaises(Exception) as context:
            link_resources_to_policy("test_policy_id", ["resource1", "resource2"])
        self.assertTrue('Error linking resources' in str(context.exception))

if __name__ == '__main__':
    unittest.main()



