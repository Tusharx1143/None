        stage('Run Python Unittests') {
            steps {
                script {
                    sh """
                    echo "Creating reports directory if it doesn't exist..."
                    mkdir -p ${REPORTS_DIR}
                    
                    echo "Running tests with xmlrunner and generating XML reports..."
                    source ${VENV_DIR}/bin/activate
                    python -m xmlrunner discover -s unittests -p "*.py" -o ${REPORTS_DIR}/

                    echo "Listing contents of ${REPORTS_DIR} for verification:"
                    ls -al ${REPORTS_DIR}
                    """

                    echo "Checking if test results were generated..."
                    if (fileExists("${REPORTS_DIR}/TESTS-TestSuite.xml")) {
                        echo "Test results found."
                    } else {
                        echo "ERROR: No test results found in ${REPORTS_DIR}/"
                        exit 1
                    }
                }
            }
        }

    post {
        always {
            archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
            junit 'reports/TESTS-TestSuite.xml'
        }
    }
}

