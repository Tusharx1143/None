function submitGroupForm() {
    const groupType = document.getElementById('groupType').value;
    const groupName = document.getElementById('groupName').value;
    const groupDescription = document.getElementById('groupDescription').value;

    fetch('/rest/v1/group/create', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            groupType: groupType,
            groupName: groupName,
            groupDescription: groupDescription
        })
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();  // Assuming your backend sends a JSON response
    })
    .then(data => {
        console.log('Group creation response:', data);
        document.getElementById('responseMessage').innerText = "Success: Group created successfully";
        document.getElementById('responseMessage').classList.add('alert-success');
        document.getElementById('responseMessage').style.display = 'block';
        document.getElementById('createGroupForm').reset();
    })
    .catch(error => {
        console.error('Error:', error);
        document.getElementById('responseMessage').innerText = `Error: Failed to create group, details: ${error}`;
        document.getElementById('responseMessage').classList.add('alert-danger');
        document.getElementById('responseMessage').style.display = 'block';
    });
}
