from cmdb_application import get_cmdb_application_by_id
from policies import create_application_set_in_asset_store
import logging

# Configure logging
logging.basicConfig(level=logging.INFO)
_log = logging.getLogger(__name__)

def migrate_cmdb_application_to_asset_store(application_name):
    """
    Migrate a CMDB application and its resources to the Asset Store.
    
    Args:
    - application_name (str): The name of the CMDB application to migrate.
    
    Returns:
    - None
    """
    # Step 1: Fetch the CMDB application by name
    cmdb_app = get_cmdb_application_by_id(application_name)
    
    if cmdb_app:
        cmdb_application_id = cmdb_app["cmdb_application_id"]
        
        # Step 2: Create Application Set in Asset Store
        application_set_response = create_application_set_in_asset_store(application_name, cmdb_application_id)
        
        if "application_set_id" in application_set_response:
            application_set_id = application_set_response["application_set_id"]
            _log.info(f"Application set {application_set_id} created successfully for {application_name}")
            
            # Step 3: Fetch and link resources (this part is already in your resource linking logic)
            # You would link the resources to the application set here...
            
        else:
            _log.error(f"Failed to create Application Set for {application_name}")
    else:
        _log.error(f"CMDB application {application_name} not found.")

# Example of running the function
if __name__ == "__main__":
    application_name = "Test Set for PPM"
    migrate_cmdb_application_to_asset_store(application_name)

