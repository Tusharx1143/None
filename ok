def get_entitlements(resource, action_filter):
    """
    Fetch entitlements from RODAN, grouped by application or functionality.
    """
    entitlements_response = requests.get(f"RODAN_API/{resource}?filter={action_filter}")
    
    entitlements = entitlements_response.json()['entitlements']
    
    # Group resources by application or functionality
    grouped_entitlements = {
        'Administrator': [e for e in entitlements if 'Admin' in e['role']],
        'User Management': [e for e in entitlements if 'User' in e['role']]
    }
    
    return grouped_entitlements
