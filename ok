# migrate_cmdb_to_asset_store.py

import logging
from cmdb_application import get_cmdb_application_by_sys_id
from policies import create_application_set_in_asset_store

# Configure logging
logging.basicConfig(level=logging.INFO)
_log = logging.getLogger(__name__)

def migrate_cmdb_application_to_asset_store(cmdb_sys_id):
    """
    Migrate a CMDB application to Asset Store by fetching CMDB application details
    and creating the application set in Asset Store.
    
    Args:
    - cmdb_sys_id (str): The sys_id of the CMDB application.
    
    Returns:
    - None
    """
    # Step 1: Fetch CMDB application details using sys_id
    cmdb_app_details = get_cmdb_application_by_sys_id(cmdb_sys_id)
    
    if cmdb_app_details:
        application_name = cmdb_app_details["name"]
        
        # Step 2: Create an Application Set in Asset Store
        asset_store_response = create_application_set_in_asset_store(cmdb_sys_id, application_name)
        
        if asset_store_response:
            _log.info(f"Application {application_name} successfully migrated to Asset Store.")
        else:
            _log.error(f"Failed to migrate {application_name} to Asset Store.")
    else:
        _log.error(f"CMDB Application with sys_id {cmdb_sys_id} not found.")

