# cmdb_application.py

def get_cmdb_application_by_sys_id(application_sys_id):  
    """
    Fetch the CMDB application details based on the sys_id (application ID).
    
    Args:
    - application_sys_id (str): The sys_id of the CMDB application.
    
    Returns:
    - dict: CMDB application details including name and sys_id (application ID).
    """
    api_url = base_url + "/applications/" + application_sys_id + "?type=JSON"
    try:
        r = requests.get(api_url, auth=(cmdb_user, cmdb_password))
        response = r.json()
        if r.status_code == HTTPStatus.NOT_FOUND:
            _log.info(msg="CMDB Application Not Found for sys_id: %s", args=application_sys_id)
            return None
        _log.debug(msg="CMDB Application response: %s", args=json.dumps(response))
        cmdb_app = dict()
        cmdb_app["name"] = response["result"][0]["name"]
        cmdb_app["sys_id"] = response["result"][0]["sys_id"]
        _log.info(msg="Fetched CMDB Application: %s", args=json.dumps(cmdb_app))
        return cmdb_app
    except Exception as error:
        _log.error("Error Fetching CMDB Application by sys_id: {}".format(str(error)))
        raise error



