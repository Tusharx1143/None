3. policies.py
New Function: create_policies_for_entitlements

Purpose: This function will create policies in PlainID based on the actions and groups extracted from the entitlements.
Why Needed: To automate policy creation and ensure policies are correctly set up with the appropriate actions and linked groups.

def create_policies_for_entitlements(application, entitlements, namespace_id):
    """
    Create policies in PlainID based on RODAN entitlements.
    
    Args:
    - application (str): The application name for naming policies.
    - entitlements (list): List of entitlements containing actions and groups.
    - namespace_id (str): The namespace ID to use for policy creation.
    
    Returns:
    - dict: Mapping of actions to policy IDs.
    """
    actions_dict = {}
    for entitlement in entitlements:
        action_name = entitlement["action"]
        policy_name = f"{application}-{action_name}-Access"
        description = policy_name
        policy = create_policy(namespace_id, policy_name, description)
        if policy and "id" in policy:
            actions_dict[action_name] = policy["id"]
            _log.info("Policy created: %s", policy_name)
        else:
            _log.error("Failed to create policy for action: %s", action_name)
    return actions_dict

# Example usage
policy_ids = create_policies_for_entitlements("MyApp", filtered_entitlements, "namespace_id_here")


