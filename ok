import logging
import requests
import json
from http import HTTPStatus

headers = config.get_headers()
__log = logging.getLogger("rest_utils")

def create_resource_type(resource_name, application_set_id, resource_attributes=[]):
    """
    Create a resource type in the PlainID Asset Store.
    
    Args:
    - resource_name (str): The name of the resource type (e.g., 'Administrator' or 'Reports').
    - application_set_id (str): The ID of the application set in which to create the resource type.
    - resource_attributes (list): Additional attributes for the resource type (optional).
    
    Returns:
    - dict: The response from the Asset Store API.
    """
    if not resource_name:
        raise Exception("Resource Name Not Found!")
    
    data = {
        "resource_name": resource_name,
        "resource_attributes": resource_attributes
    }

    try:
        url = f"{api_url}/{application_set_id}/resources-type"
        r = requests.post(url=url, data=json.dumps(data), headers=headers, auth=(asset_store_user, asset_store_password))
        response = r.json()
        if r.status_code == HTTPStatus.OK:
            __log.info(f"Resource type {resource_name} created successfully")
            return response
        else:
            raise Exception(f"Error creating resource type: {r.status_code}, {r.text}")
    except Exception as error:
        __log.error(f"Error while creating resource type: {str(error)}")
        raise error

def create_resource(application_set_id, resource_type_id, resource_name):
    """
    Create a resource in the PlainID Asset Store under the given resource type.
    
    Args:
    - application_set_id (str): The ID of the application set.
    - resource_type_id (str): The ID of the resource type.
    - resource_name (str): The name of the resource to create (e.g., '/ppm/PPM/Administrator/Resource').
    
    Returns:
    - dict: The response from the Asset Store API.
    """
    data = {
        "resource_name": resource_name
    }

    try:
        url = f"{api_url}/{application_set_id}/resources-type/{resource_type_id}/resources"
        r = requests.post(url=url, data=json.dumps(data), headers=headers, auth=(asset_store_user, asset_store_password))
        response = r.json()
        if r.status_code == HTTPStatus.OK:
            __log.info(f"Resource {resource_name} created successfully")
            return response
        else:
            raise Exception(f"Error creating resource: {r.status_code}, {r.text}")
    except Exception as error:
        __log.error(f"Error while creating resource: {str(error)}")
        raise error

