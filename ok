5. rest_utils.py
New Function: make_request_with_retry_and_logging

Purpose: Utilize this utility function to make API requests to RODAN and PlainID with retry mechanisms.
Why Needed: To ensure robustness in network communication and handle transient errors effectively.

def make_request_with_retry_and_logging(request_func, url, max_retries=5, initial_retry_delay=2, max_retry_delay=30, **kwargs):
    """
    Make a REST API request with retry logic and logging.
    
    Args:
    - request_func (function): Function to call for making the request.
    - url (str): The URL to make the request to.
    - max_retries (int): Maximum number of retry attempts.
    - initial_retry_delay (int): Initial delay between retries.
    - max_retry_delay (int): Maximum delay between retries.
    
    Returns:
    - Response: The API response, or None if all retries fail.
    """
    retry_delay = initial_retry_delay
    attempt = 0
    while attempt < max_retries:
        try:
            response = request_func(url, **kwargs)
            if response and 200 <= response.status_code < 300:
                return response
            elif response.status_code >= 500:
                _log.warning(f"Server error {response.status_code}: {response.reason}. Retrying in {retry_delay} seconds...")
            else:
                _log.error(f"Unexpected response: {response.status_code} - {response.reason}")
                return response
        except Exception as e:
            _log.warning(f"Attempt {attempt + 1} for {url} failed: {e}. Retrying in {retry_delay} seconds...")
        attempt += 1
        time.sleep(retry_delay)
        retry_delay = min(max_retry_delay, retry_delay * 2)
    _log.error(f"Failed to connect to {url} after {max_retries} attempts.")
    return None

# Example usage
response = make_request_with_retry_and_logging(requests.get, "http://example.com/api")


