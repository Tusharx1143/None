2. resources.py: Map RODAN Resources to Asset Store

This file will include the logic for creating resources in the Asset Store using the POST API.

# resources.py

import json
import logging
import requests
from http import HTTPStatus
import config

_log = logging.getLogger("resources")

api_url = config.get_arg("assetstore.url")  # Base URL for Asset Store API
headers = config.get_headers()

def create_resource(application_set_id, resource_type_id, resource_name):
    """
    Create a resource in the Asset Store under the given application set.
    
    Args:
    - application_set_id (str): ID of the application set.
    - resource_type_id (str): Type of the resource (optional).
    - resource_name (str): The name of the resource to create.
    
    Returns:
    - dict: The response from the Asset Store API.
    """
    data = {
        "resource_name": resource_name,
        "resource_type": resource_type_id
    }
    
    try:
        url = f"{api_url}/{application_set_id}/resources"
        response = requests.post(url, headers=headers, data=json.dumps(data))
        if response.status_code == HTTPStatus.OK:
            return response.json()
        else:
            _log.error(f"Failed to create resource: {resource_name}, Status: {response.status_code}")
            return {}
    except Exception as error:
        _log.error(f"Error creating resource {resource_name}: {str(error)}")
        return {}

def map_rodan_resources_to_asset_store(application_set_id, rodan_resources):
    """
    Map and create resources from RODAN in the Asset Store.
    
    Args:
    - application_set_id (str): The application set ID in which the resources should be created.
    - rodan_resources (list): List of resources extracted from RODAN.
    
    Returns:
    - dict: A dictionary mapping resource names to Asset Store resource IDs.
    """
    resources_dict = {}
    for resource_name in rodan_resources:
        try:
            resource_response = create_resource(application_set_id, resource_type_id=None, resource_name=resource_name)
            if resource_response.get('resource_map_key'):
                resources_dict[resource_name] = resource_response['resource_map_key']
                _log.info(f"Resource {resource_name} created in Asset Store")
            else:
                _log.error(f"Resource creation failed for {resource_name}")
        except Exception as error:
            _log.error(f"Failed to create resource {resource_name}: {str(error)}")
    return resources_dict

Changes:

create_resource(): Makes a POST API call to create resources in the Asset Store using RODAN data.

map_rodan_resources_to_asset_store(): Iterates over RODAN resources and creates each resource in the Asset Store.



