import unittest
from unittest.mock import patch, Mock
from policies import link_resources_to_policy

class TestLinkResourcesToPolicy(unittest.TestCase):

    @patch('policies.requests.post')
    def test_link_resources_to_policy_success(self, mock_post):
        """
        Test case for successful linking of resources to policy
        """
        # Mock the response to simulate a successful API call (status code 200)
        mock_response = Mock()
        mock_response.status_code = 200
        mock_post.return_value = mock_response

        # Call the function with mock data
        policy_id = "test_policy_id"
        resource_ids = ["resource1", "resource2"]

        # Since the function does not return anything, we just assert that no exceptions are raised
        link_resources_to_policy(policy_id, resource_ids)

        # Ensure that the API was called with the correct data
        mock_post.assert_called_once_with(
            url=f"http://example.com/{policy_id}/resources",  # URL should match the expected format
            data='{"resources": ["resource1", "resource2"]}',  # Payload should be JSON with the correct resources
            headers={"Content-type": "application/json"},      # Ensure headers are correct
            auth=('plainid_user', 'plainid_password')          # Ensure auth is passed correctly
        )

