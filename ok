import requests
import json
import logging
from requests.auth import HTTPBasicAuth
from http import HTTPStatus
from config import config

# Headers and API configuration
headers = {"Content-type": "application/json"}

_log = logging.getLogger('config')

# API configurations
plainid_base_url = config.get_arg("plainid.url")
plainid_api_url = plainid_base_url + "/rest/permission"
plainid_user = config.get_arg("plainid.user")
plainid_password = config.get_arg("plainid.password")

asset_store_base_url = config.get_arg("assetstore.url")
asset_store_api_url = asset_store_base_url + "/api/v1/application-sets"  # version: v1
asset_store_user = config.get_arg("assetstore.user")
asset_store_password = config.get_arg("assetstore.password")

# Function to create a dynamic group in PlainID
def create_dynamic_group(group_name, group_type="swarm", description=""):
    _log.info(f"Creating dynamic group: {group_name}")
    group_data = {
        "groupType": group_type,
        "groupName": group_name,
        "groupDescription": description
    }
    try:
        response = requests.post(
            f"{plainid_base_url}/rest/v1/group/create",
            headers={"Content-Type": "application/json"},
            data=json.dumps(group_data),
            auth=HTTPBasicAuth(plainid_user, plainid_password)
        )
        if response.status_code == HTTPStatus.CREATED:
            _log.info(f"Dynamic group '{group_name}' created successfully.")
            return response.json().get("id")
        elif response.status_code == HTTPStatus.CONFLICT:
            _log.warning(f"Dynamic group '{group_name}' already exists.")
            return get_group_id(group_name)  # Get existing group ID
        else:
            _log.error(f"Error creating dynamic group '{group_name}': {response.status_code} - {response.text}")
    except Exception as error:
        _log.error(f"Error creating dynamic group '{group_name}': {str(error)}")
    return None

# Function to create a policy in PlainID
def create_policy(namespace_id, policy_name, policy_description, namespace_usage="PRIVATE"):
    data = {
        "objectType": "POLICY_OBJ",
        "name": policy_name,
        "description": policy_description,
        "namespace": namespace_id,
        "namespaceUsage": namespace_usage,
        "active": True,
        "restricted": False
    }

    _log.info(f"Creating policy: {policy_name}")
    try:
        r = requests.put(
            plainid_api_url,
            data=json.dumps(data),
            auth=(plainid_user, plainid_password),
            headers=headers
        )
        response = r.json()
        if r.status_code == HTTPStatus.OK:
            _log.info(f"Created policy with ID: {response['id']}")
            return response['id']
        else:
            _log.error(f"Unexpected response code from REST call: {r.status_code} - {r.text}")
    except Exception as error:
        _log.error(f"Error creating policy {policy_name}: {str(error)}")
        raise error
    return None

# Function to link dynamic list to policy in PlainID
def link_dynamic_list_to_policy(permission, resources):
    data = [{"permission": permission, "resources": resources}]
    _log.info("Linking dynamic list to policy")
    try:
        url = plainid_base_url + "/rest/xresource/link"
        r = requests.post(url, data=json.dumps(data), auth=(plainid_user, plainid_password), headers=headers)
        if r.status_code == HTTPStatus.OK:
            _log.info("Linked dynamic list to policy")
        else:
            _log.error(f"Unexpected response code from REST call: {r.status_code} - {r.text}")
    except Exception as error:
        _log.error(f"Error linking dynamic list to policy: {str(error)}")
        raise error

# Function to create an application set in the Asset Store
def create_application_set(application_cmdb_sys_id, application_set_name, application_set_description):
    _log.info(f"Creating application set: {application_set_name}")
    payload = {
        "application_cmdb_sys_id": application_cmdb_sys_id,
        "application_set_name": application_set_name,
        "application_set_description": application_set_description
    }
    try:
        r = requests.post(
            url=asset_store_api_url,
            data=json.dumps(payload),
            headers=headers,
            auth=(asset_store_user, asset_store_password)
        )
        if r.status_code == HTTPStatus.OK:
            _log.info(f"Application set '{application_set_name}' created.")
            return r.json()
        else:
            _log.error(f"Unexpected response code from REST call: {r.status_code} - {r.text}")
    except Exception as error:
        _log.error(f"Error creating application set: {str(error)}")
        raise error

# Function to create an asset in the Asset Store
def create_or_update_asset(application_set, resource_path, attributes):
    _log.info(f"Creating/Updating Asset for Resource Path: {resource_path}")
    asset_data = {
        "applicationSet": application_set,
        "resourceType": "Resource_Type",
        "resourcePath": resource_path,
        "attributes": attributes
    }
    response = requests.post(
        f"{asset_store_api_url}/resources",
        headers={"Content-Type": "application/json"},
        data=json.dumps(asset_data),
        auth=HTTPBasicAuth(asset_store_user, asset_store_password)
    )
    if response.status_code == HTTPStatus.CREATED:
        _log.info(f"Asset for resource '{resource_path}' created successfully.")
        return response.json().get("id")
    else:
        _log.error(f"Error creating asset for '{resource_path}': {response.status_code} - {response.text}")
        return None

