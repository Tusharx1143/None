# cmdb_application.py
def get_cmdb_application_by_id(application_name):
    """
    Fetch the CMDB application by name and return the application ID (sys_id).
    
    Args:
    - application_name (str): The name of the CMDB application to fetch.
    
    Returns:
    - dict: Contains the application name and sys_id.
    """
    try:
        cmdb_app = get_cmdb_application(application_name)
        if cmdb_app:
            return {
                "application_name": cmdb_app["name"],
                "cmdb_application_id": cmdb_app["sys_id"]
            }
        else:
            _log.error(f"CMDB Application {application_name} not found.")
            return None
    except Exception as error:
        _log.error(f"Error fetching CMDB application {application_name}: {str(error)}")
        return None



