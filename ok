# resources.py
def create_rodan_resources_in_asset_store(application_set_id, rodan_resources):
    """
    Create RODAN resources in the Asset Store under a specific application set.
    
    Args:
    - application_set_id (str): The ID of the application set in Asset Store.
    - rodan_resources (list): A list of resources fetched from RODAN.
    
    Returns:
    - dict: A mapping of RODAN resource names to Asset Store resource IDs.
    """
    resource_mapping = {}
    for resource in rodan_resources:
        try:
            # Creating resource in the Asset Store
            resource_response = create_resource(application_set_id, None, resource["resource_name"])
            if "resource_map_key" in resource_response:
                resource_mapping[resource["resource_name"]] = resource_response["resource_map_key"]
                _log.info(f"Resource {resource['resource_name']} created successfully in Asset Store")
            else:
                _log.error(f"Failed to create resource {resource['resource_name']} in Asset Store")
        except Exception as error:
            _log.error(f"Error creating resource {resource['resource_name']}: {str(error)}")
    return resource_mapping

Explanation: This function creates each RODAN resource in the Asset Store and returns a mapping of resource names to their corresponding Asset Store resource IDs.


