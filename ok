                    source ${VENV_DIR}/bin/activate

                    # Simple Python test case to ensure environment works
                    echo 'def test_sample(): assert True' > unittests/test_sample.py
                    pytest unittests/

                    # List the content of the test directory for visibility
                    ls -al unittests/
                    """
                }
            }
        }

        stage('Run Python Unittests with xmlrunner') {
            steps {
                script {
                    sh """
                    echo "Running tests with xmlrunner..."
                    source ${VENV_DIR}/bin/activate
                    mkdir -p ${REPORTS_DIR}
                    python -m xmlrunner discover -s unittests -p "*.py" -o ${REPORTS_DIR}/

                    echo "Listing contents of ${REPORTS_DIR}:"
                    ls -al ${REPORTS_DIR}
                    """
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: '**/target/*.jar', allowEmptyArchive: true
            junit 'reports/TESTS-TestSuite.xml'
        }
    }
