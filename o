Explanation of Mocking
Mocking: This is a technique used in unit testing where dependencies (like API calls or database connections) are replaced with mock objects. This allows the tests to focus solely on the logic of the function being tested, rather than the behavior of external systems.
@patch('utils.cmdb_applications.requests.get'): This decorator replaces the requests.get method in the cmdb_applications module with a mock object for the duration of the test.
mock_get_arg.side_effect: This allows you to specify different return values based on the argument passed to the get_arg function.
mock_response.json.return_value: This sets the return value of the json() method on the mocked response object.








import unittest
from unittest.mock import patch, MagicMock
from utils import cmdb_applications


class TestCmdbApplications(unittest.TestCase):

    @patch('utils.cmdb_applications.requests.get')
    @patch('utils.cmdb_applications.config.get_arg')
    def test_get_all_cmdb_applications(self, mock_get_arg, mock_requests_get):
        mock_get_arg.side_effect = lambda arg: {
            "cmdb.url": "http://mockurl.com",
            "cmdb.user": "mockuser",
            "cmdb.password": "mockpassword"
        }.get(arg)

        mock_response = MagicMock()
        mock_response.json.return_value = {
            "result": [
                {"name": "App1", "sys_id": "1", "u_active": True},
                {"name": "App2", "sys_id": "2", "u_active": True},
                {"name": None, "sys_id": "3", "u_active": False}
            ]
        }
        mock_requests_get.return_value = mock_response

        result = cmdb_applications.get_all_cmdb_applications()
        expected_result = {"App1": "1", "App2": "2"}

        self.assertEqual(result, expected_result)

    @patch('utils.cmdb_applications.requests.get')
    @patch('utils.cmdb_applications.config.get_arg')
    def test_get_cmdb_application(self, mock_get_arg, mock_requests_get):
        mock_get_arg.side_effect = lambda arg: {
            "cmdb.url": "http://mockurl.com",
            "cmdb.user": "mockuser",
            "cmdb.password": "mockpassword"
        }.get(arg)

        mock_response = MagicMock()
        mock_response.json.return_value = {
            "result": [{"sys_id": "1"}]
        }
        mock_requests_get.return_value = mock_response

        result = cmdb_applications.get_cmdb_application("App1")
        expected_result = {"name": "App1", "sys_id": "1"}

        self.assertEqual(result, expected_result)

    @patch('utils.cmdb_applications.get_plainid_apps')
    def test_reconcile_plainid_cmdb(self, mock_get_plainid_apps):
        cmdb_apps = {"App1": "1", "App2": "2"}
        mock_get_plainid_apps.return_value = {
            "1": {"Application": "App1"},
            "2": {"Application": "App2"},
            "3": {"Application": "App3"}
        }

        result = cmdb_applications.reconcile_plainid_cmdb(cmdb_apps, None)
        expected_result = {
            "1": {"Application": "App1", "result": "Match"},
            "2": {"Application": "App2", "result": "Match"},
            "3": {"Application": "App3", "result": "Unmatched"}
        }

        self.assertEqual(result, expected_result)

    @patch('utils.cmdb_applications.namespace.get_applications_namespace_id')
    @patch('utils.cmdb_applications.namespace.create_application_namespace')
    @patch('utils.cmdb_applications.namespace.get_namespaces_by_id')
    @patch('utils.cmdb_applications.config.get_propstore_env')
    @patch('utils.cmdb_applications.client.create')
    def test_setup_application_into_plainid(self, mock_create_client, mock_get_propstore_env, mock_get_namespaces_by_id, mock_create_namespace, mock_get_namespace_id):
        # Mock return values for namespace and client functions
        mock_get_namespace_id.return_value = "namespace_rid"
        mock_create_namespace.return_value = "new_namespace_rid"
        mock_get_namespaces_by_id.return_value = [{"name": "App1", "description": "1"}]
        mock_create_client.return_value = "client_id"
        mock_get_propstore_env.return_value = cmdb_applications.Environments.Demo

        application = {"name": "App1", "sys_id": "1"}
        connection_pool = MagicMock()

        cmdb_applications.setup_application_into_plainid(application, connection_pool)

        # Check if certain methods were called
        mock_create_namespace.assert_called()
        mock_create_client.assert_called_with(application_sys_id="1", application_name="App1", scope_id='id', connection_pool=connection_pool)

if __name__ == '__main__':
    unittest.main()




