import requests
import time
import random
import logging

__log = logging.getLogger('rest_utils')

def make_request_with_retry(request_func, url, max_retries=5, initial_retry_delay=2, max_retry_delay=30, **kwargs):
    retry_delay = initial_retry_delay
    attempt = 0

    while attempt < max_retries:
        try:
            response = request_func(url, **kwargs)
            if response:
                if 200 <= response.status_code < 300:
                    return response
                elif response.status_code >= 500:
                    __log.warning(f"Server error {response.status_code}: {response.reason}. Retrying in {retry_delay} seconds...")
                else:
                    __log.error(f"Unexpected response: {response.status_code} - {response.reason}")
                    return response
            else:
                __log.error("Null response returned")
                return None
        except requests.RequestException as e:
            __log.warning(f"Attempt {attempt + 1} for {url} failed: {e}. Retrying in {retry_delay} seconds...")

        attempt += 1
        time.sleep(retry_delay)
        retry_delay = min(max_retry_delay, retry_delay * 2) + random.uniform(0, 5)  # Exponential backoff with jitter

    __log.error(f"Failed to connect to {url} after {max_retries} attempts.")
    return None

def do_put(url, payload, auth, expected_status, namespace=None):
    headers = {}  # Add your headers initialization if any
    def request_func(url, **kwargs):
        return requests.put(url, data=payload, headers=headers, auth=auth, timeout=20000)
    
    response = make_request_with_retry(request_func, url)

    if response and response.status_code == expected_status:
        __log.info("Request completed successfully %s:%s", url, payload)
        return True
    elif response:
        __log.debug("Unexpected response: " + str(response.status_code) + " : " + response.reason)
        return False
    else:
        __log.error("Null response or failed request")
        return False

def do_post(url, payload, auth, expected_status):
    headers = {}  # Add your headers initialization if any
    def request_func(url, **kwargs):
        return requests.post(url, data=payload, headers=headers, auth=auth, timeout=20000)
    
    response = make_request_with_retry(request_func, url)

    if response and response.status_code == expected_status:
        __log.info("Request completed successfully %s:%s", url, payload)
        return response.text
    elif response:
        __log.debug("Unexpected response: " + str(response.status_code) + " : " + response.reason)
        return None
    else:
        __log.error("Null response or failed request")
        return None




import unittest
from unittest.mock import patch, MagicMock
import requests
from rest_utils import do_post, make_request_with_retry

class TestRestUtils(unittest.TestCase):

    @patch('rest_utils.requests.post')
    def test_retry_on_500_error(self, mock_post):
        # Simulate a server error (500) response
        mock_response = MagicMock()
        mock_response.status_code = 500
        mock_response.reason = "Internal Server Error"
        mock_post.return_value = mock_response

        # Test the retry logic
        with patch('rest_utils.time.sleep', return_value=None):  # To skip the actual sleep
            response = do_post('http://example.com', payload={}, auth=None, expected_status=200)

        # Check that the function retried the maximum number of times
        self.assertEqual(mock_post.call_count, 5)
        self.assertIsNone(response)

    @patch('rest_utils.requests.post')
    def test_retry_on_connection_error(self, mock_post):
        # Simulate a connection error
        mock_post.side_effect = requests.exceptions.ConnectionError()

        # Test the retry logic
        with patch('rest_utils.time.sleep', return_value=None):  # To skip the actual sleep
            response = do_post('http://example.com', payload={}, auth=None, expected_status=200)

        # Check that the function retried the maximum number of times
        self.assertEqual(mock_post.call_count, 5)
        self.assertIsNone(response)

    @patch('rest_utils.requests.post')
    def test_success_after_retries(self, mock_post):
        # Simulate a connection error first, then a successful response
        mock_post.side_effect = [requests.exceptions.ConnectionError(),
                                 requests.exceptions.ConnectionError(),
                                 MagicMock(status_code=200, text="Success")]

        # Test the retry logic
        with patch('rest_utils.time.sleep', return_value=None):  # To skip the actual sleep
            response = do_post('http://example.com', payload={}, auth=None, expected_status=200)

        # Check that the function retried until it got a successful response
        self.assertEqual(mock_post.call_count, 3)
        self.assertEqual(response, "Success")

    @patch('rest_utils.requests.post')
    def test_no_retry_on_400_error(self, mock_post):
        # Simulate a client error (400) response
        mock_response = MagicMock()
        mock_response.status_code = 400
        mock_response.reason = "Bad Request"
        mock_post.return_value = mock_response

        # Test the retry logic
        with patch('rest_utils.time.sleep', return_value=None):  # To skip the actual sleep
            response = do_post('http://example.com', payload={}, auth=None, expected_status=200)

        # Check that the function did not retry on a 400 error
        self.assertEqual(mock_post.call_count, 1)
        self.assertIsNone(response)

if __name__ == '__main__':
    unittest.main()




