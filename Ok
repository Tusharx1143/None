SELECT 
   Names,
   [26],
   [27],
   [28],
   [29],
   [30],
   (CASE WHEN [26] != '' THEN 1 ELSE 0 END +
    CASE WHEN [27] != '' THEN 1 ELSE 0 END +
    CASE WHEN [28] != '' THEN 1 ELSE 0 END +
    CASE WHEN [29] != '' THEN 1 ELSE 0 END +
    CASE WHEN [30] != '' THEN 1 ELSE 0 END
   ) AS [Seats Occupied]
FROM T*
GROUP BY 
   Names,
   [26],
   [27],
   [28],
   [29],
   [30]
ORDER BY Names
