        # Test the retry logic
        with patch('rest_utils.time.sleep', return_value=None):  # To skip the actual sleep
            response = do_post('http://example.com', payload={}, auth=None, expected_status=200)

        # Check that the function retried the maximum number of times
        self.assertEqual(mock_post.call_count, 5)
        self.assertIsNone(response)

